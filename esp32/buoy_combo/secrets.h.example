#ifndef SECRETS_H
#define SECRETS_H

// --- NTRIP (RTK corrections) ---
const char *casterHost   = "132.239.117.27";
const uint16_t casterPort = 2101;
const char *mountPoint   = "BASE_CCS";
const char *casterUser   = "your_user";
const char *casterUserPW = "your_password";

// --- Telemetry (pick one path) ---

// === Path A: Public GitHub Pages dashboard via Hologram (recommended) ===
// Buoy --TCP--> Hologram Cloud Socket --Alert webhook--> Cloudflare Worker
//      --> GitHub repository_dispatch --> docs/data.json --> Pages
// Works on SIM7000A B03 firmware (no HTTPS from modem required).
// See documentation/github-pages.md for the Hologram Alert setup.
#define HAS_HOLOGRAM_DEVICE_KEY 1
const char hologramDeviceKey[] = "";  // 8-char key from Hologram dashboard --> device --> Router Credentials

// telemetrySecret is unused by the Hologram relay path (the Hologram Alert
// attaches the BUOY_SECRET header). Keep configured for the direct-HTTPS
// path below in case the modem is ever upgraded.
#define HAS_TELEMETRY_SECRET 1
const char *telemetrySecret = "your-buoy-secret";

// === Path B: Local dashboard via ngrok (development) ===
// Buoy --TCP--> ngrok --> local_portal/server.py --> browser on your PC
// See documentation/local-portal.md. Uncomment and paste the ngrok address.
//#define HAS_TELEMETRY_URL 1
//const char *telemetryUrl = "tcp://0.tcp.ngrok.io:NNNNN/api/ingest";

// === Path C: Direct HTTPS to Cloudflare Worker (needs B05+ modem) ===
// Bypasses Hologram, but SIM7000A B03 cannot do this reliably.
//#define HAS_TELEMETRY_URL 1
//const char *telemetryUrl = "https://YOUR-WORKER.workers.dev";

#ifndef TELEMETRY_INTERVAL_MS
#define TELEMETRY_INTERVAL_MS 60000UL
#endif

#endif
